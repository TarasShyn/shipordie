# twitterapi.io API key — the hourly cron pulls the crew's recent posts from the X
# list and pins them to each pirate. Without it the ship falls back to the demo
# posts baked into data/members.json.
TWITTER_API_API_KEY=""

# Optional shared secret guarding /api/cron/sync-posts. When set, the hourly
# trigger must send `Authorization: Bearer <secret>` (or `?secret=`).
CRON_SECRET=""

# Skip Next env validation during local dev.
SKIP_ENV_VALIDATION=true
